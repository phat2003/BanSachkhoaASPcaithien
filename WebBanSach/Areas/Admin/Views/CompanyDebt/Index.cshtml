@model IEnumerable<BanSach.Models.ViewModel.CompanyDebtVM>

<div class="container p-3">
    <div class="row pt-4">
        <div class="col-6">
            <h2 class="text-primary">Quản lý Công nợ Công ty 🏦</h2>
        </div>
    </div>
    
    <br /><br />

    <table class="table table-bordered table-striped" style="width:100%">
        <thead>
            <tr>
                <th>Tên Công ty</th>
                <th>Địa chỉ</th>
                <th>Số điện thoại</th>
                <th>Tổng dư nợ (VND)</th>
                <th>Hành động</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var obj in Model)
            {
                <tr>
                    <td width="25%">@obj.company.Name</td>
                    <td width="25%">@obj.company.StreetAddress, @obj.company.City</td>
                    <td width="15%">@obj.company.PhoneNumber</td>
                    <td width="20%" class="text-danger fw-bold">
                        @obj.TotalDebt.ToString("N0") đ
                    </td>
                    <td width="15%">
                        <div class="w-75 btn-group" role="group">
                            <a asp-controller="CompanyDebt" asp-action="Details" asp-route-companyId="@obj.company.Id"
                               class="btn btn-primary mx-2"> <i class="bi bi-eye"></i> Chi tiết nợ</a>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>