@model IEnumerable<BanSach.Models.OrderHeader>

<div class="container p-3">
    <div class="row pt-4">
        <div class="col-12">
            <h2 class="text-primary">Chi tiết công nợ - @ViewData["CompanyName"] 🏢</h2>
        </div>
    </div>

    <br />

    <table class="table table-bordered table-striped" style="width:100%">
        <thead>
            <tr>
                <th>Mã đơn hàng</th>
                <th>Ngày đặt</th>
                <th>Người đặt</th>
                <th>Tổng tiền</th>
                <th>Trạng thái</th>
                <th>Hành động</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var obj in Model)
            {
                <tr>
                    <td>@obj.Id</td>
                    <td>@obj.OrderDate.ToShortDateString()</td>
                    <td>@obj.Name</td>
                    <td class="text-danger fw-bold">@obj.OrderTotal.ToString("N0") đ</td>
                    <td>
                        <span class="badge bg-warning text-dark">@obj.PaymentStatus</span>
                    </td>
                    <td>
                        <a asp-controller="Order" asp-action="Details" asp-route-Id="@obj.Id"
                               class="btn btn-info mx-2">
                            <i class="bi bi-eye"></i> Xem đơn
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>